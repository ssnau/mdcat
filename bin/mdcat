#!/usr/bin/env node
const { program } = require('commander');
const pkg = require('../package.json');
const component = require('../lib/index');

program
  .version(pkg.version)
  .argument('<file>', 'markdown file to preview')
  .action((file) => {
    const cwd = process.cwd();

    component({
      name: file,
      cwd: cwd
    }).catch(function(e) {
      console.log('Error!', e, e.stack);
    });
  })
  .parse(process.argv);
